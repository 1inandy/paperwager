# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SECRET_KEY=

# Auth redirects (required in production)
APP_URL=http://localhost:3000

# Guest sessions — generate with: openssl rand -hex 32
GUEST_SESSION_SECRET=

# Cron protection — generate with: openssl rand -hex 32
CRON_SECRET=

# Market odds (production)
ODDS_API_KEY=
ODDS_PROVIDER=api
MARKET_BOOKMAKER=draftkings
ODDS_SYNC_SPORT_KEYS=

# Model
MODEL_LINES_ENABLED=true
MODEL_TRAIN_DAYS=30

# Admin access (comma-separated)
ADMIN_USER_IDS=
ADMIN_EMAILS=
